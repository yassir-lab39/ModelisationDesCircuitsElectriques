                  <subModelOperations xsi:type="tool_1:SetValue" featureName="fabricant" valueExpression="aql:'Fabricant'"/>
                  <subModelOperations xsi:type="tool_1:CreateInstance" typeName="catalogue::Empreinte" referenceName="empreinte" variableName="newEmpreinte">
                    <subModelOperations xsi:type="tool_1:SetValue" featureName="largeur" valueExpression="aql:10.0"/>
                    <subModelOperations xsi:type="tool_1:SetValue" featureName="hauteur" valueExpression="aql:5.0"/>
                  </subModelOperations>
                  <subModelOperations xsi:type="tool_1:CreateInstance" typeName="catalogue::Port" referenceName="ports" variableName="port1">
                    <subModelOperations xsi:type="tool_1:SetValue" featureName="nom" valueExpression="aql:'IN'"/>
                    <subModelOperations xsi:type="tool_1:SetValue" featureName="type" valueExpression="aql:catalogue::TypePort::ENTREE"/>
                  </subModelOperations>
                  <subModelOperations xsi:type="tool_1:CreateInstance" typeName="catalogue::Port" referenceName="ports" variableName="port2">
                    <subModelOperations xsi:type="tool_1:SetValue" featureName="nom" valueExpression="aql:'OUT'"/>
                    <subModelOperations xsi:type="tool_1:SetValue" featureName="type" valueExpression="aql:catalogue::TypePort::SORTIE"/>
                  </subModelOperations>
                </subModelOperations>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
          <ownedTools xsi:type="tool:ContainerCreationDescription" name="CreateDiode" containerMappings="//@ownedViewpoints[name='catalogueViewpoint']/@ownedRepresentations[name='catalogue']/@defaultLayer/@containerMappings[name='ComposantContainer']">
