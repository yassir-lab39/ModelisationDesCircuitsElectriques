          <ownedTools xsi:type="tool:ContainerCreationDescription" name="CreateBobine" containerMappings="//@ownedViewpoints[name='catalogueViewpoint']/@ownedRepresentations[name='catalogue']/@defaultLayer/@containerMappings[name='ComposantContainer']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="[container/]">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="catalogue.Composant" referenceName="composants">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="nom" valueExpression="aql:'bobine'"/>
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="fabricant" valueExpression="aql:'Fabricant'"/>
                  <subModelOperations xsi:type="tool_1:CreateInstance" typeName="catalogue::Empreinte" referenceName="empreinte" variableName="newEmpreinte">
                    <subModelOperations xsi:type="tool_1:SetValue" featureName="largeur" valueExpression="aql:10.0"/>
                    <subModelOperations xsi:type="tool_1:SetValue" featureName="hauteur" valueExpression="aql:5.0"/>
                  </subModelOperations>
