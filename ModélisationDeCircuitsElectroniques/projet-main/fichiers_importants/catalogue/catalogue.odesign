          <ownedTools xsi:type="tool:ContainerCreationDescription" name="CreateGenerateur" containerMappings="//@ownedViewpoints[name='catalogueViewpoint']/@ownedRepresentations[name='catalogue']/@defaultLayer/@containerMappings[name='ComposantContainer']">
            <variable name="container"/>
