<?xml version="1.0" encoding="UTF-8"?>
<lay:Layout
    xmi:version="2.0"
    xmlns:xmi="http://www.omg.org/XMI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:lay="http://www.example.org/layout"
    nom="Layout_Circuit_RLC_Serie"
    version="1.0"
    auteur="L12_5">
  <netlistRef
      href="../../fr.n7.circuits.netlist/model/Netlist1.xmi#_RLC_NETLIST"/>
  <boards xmi:id="BOARD_1"
      nom="PCB Principal RLC"
      largeur="100.0"
      hauteur="60.0">
    <couches
        xsi:type="lay:CoucheExterne"
        xmi:id="LAYER_TOP"
        nom="dessus">
      <pistes
          xmi:id="TRACK_1"
          largeur="0.5">
        <points
            x="18.0"
            y="30.0"/>
        <points
            x="30.0"
            y="30.0"/>
        <portsConnectes
            href="../../fr.n7.circuits.netlist/model/Netlist1.xmi#RP_GEN1_PLUS"/>
        <portsConnectes
            href="../../fr.n7.circuits.netlist/model/Netlist1.xmi#RP_C1_A"/>
      </pistes>
      <pistes
          xmi:id="TRACK_2"
          largeur="1.0">
        <points
            x="36.0"
            y="30.0"/>
        <points
            x="50.0"
            y="30.0"/>
        <portsConnectes
            href="../../fr.n7.circuits.netlist/model/Netlist1.xmi#RP_R1_B"/>
        <portsConnectes
            href="../../fr.n7.circuits.netlist/model/Netlist1.xmi#RP_C1_B"/>
      </pistes>
      <pistes
          xmi:id="TRACK_3"
          largeur="1.5">
        <points
            x="57.0"
            y="30.0"/>
        <points
            x="70.0"
            y="30.0"/>
        <portsConnectes
            href="../../fr.n7.circuits.netlist/model/Netlist1.xmi#RP_L1_A"/>
        <portsConnectes
            href="../../fr.n7.circuits.netlist/model/Netlist1.xmi#RP_GEN1_MOINS"/>
        <portsConnectes
            href="../../fr.n7.circuits.netlist/model/Netlist1.xmi#RP_C1_A"/>
      </pistes>
      <pistes
          xmi:id="TRACK_4"
          largeur="2.0">
        <points
            x="70.0"
            y="35.0"/>
        <points
            x="70.0"
            y="45.0"/>
        <points
            x="10.0"
            y="45.0"/>
        <points
            x="10.0"
            y="30.0"/>
        <portsConnectes
            href="../../fr.n7.circuits.netlist/model/Netlist1.xmi#RP_L1_B"/>
        <portsConnectes
            href="../../fr.n7.circuits.netlist/model/Netlist1.xmi#RP_R1_A"/>
      </pistes>
      <placements
          xmi:id="PL_GEN1"
          x="10.0"
          y="30.0">
        <instanceComposant
            href="../../fr.n7.circuits.netlist/model/Netlist1.xmi#GEN1"/>
      </placements>
      <placements
          xmi:id="PL_R1"
          x="30.0"
          y="30.0">
        <instanceComposant
            href="../../fr.n7.circuits.netlist/model/Netlist1.xmi#R1"/>
      </placements>
      <placements
          xmi:id="PL_L1"
          x="50.0"
          y="30.0">
        <instanceComposant
            href="../../fr.n7.circuits.netlist/model/Netlist1.xmi#L1"/>
      </placements>
      <placements
          xmi:id="PL_C1"
          x="70.0"
          y="30.0"
          rotation="90.0">
        <instanceComposant
            href="../../fr.n7.circuits.netlist/model/Netlist1.xmi#C1"/>
      </placements>
    </couches>
    <couches
        xsi:type="lay:CoucheInterne"
        xmi:id="LAYER_INT1"
        nom="Ground Plane"
        ordreZ="2">
      <pistes
          largeur="8.0">
        <points
            x="2.0"
            y="5.0"/>
        <points
            x="3.0"
            y="6.0"/>
        <portsConnectes
            href="../../fr.n7.circuits.netlist/model/Netlist1.xmi#RP_GEN1_PLUS"/>
        <portsConnectes
            href="../../fr.n7.circuits.netlist/model/Netlist1.xmi#RP_R1_A"/>
      </pistes>
    </couches>
    <couches
        xsi:type="lay:CoucheExterne"
        xmi:id="LAYER_BOTTOM"
        nom="dessous"
        ordreZ="1"
        face="DESSOUS"/>
  </boards>
</lay:Layout>
